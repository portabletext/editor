{
  "extends": "//",
  "linter": {
    "rules": {
      "complexity": {
        "useLiteralKeys": "off"
      },
      "style": {
        "useConsistentObjectDefinitions": "error",
        "noRestrictedGlobals": {
          "level": "error",
          "options": {
            "deniedGlobals": {
              "JSON": "Use `safeStringify`/`safeParse` instead of `JSON.stringify`/`JSON.parse` to avoid crashes on circular references."
            }
          }
        }
      }
    }
  }
}
